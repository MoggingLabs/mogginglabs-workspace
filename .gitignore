node_modules/
out/
dist/

# The standalone Node helper (ADR 0016) is BUILT, never committed: a ~90MB pinned
# runtime + helper-ABI natives (under node_deps/) per platform-arch, plus a
# <platform>-<arch>.stamp.json (scripts/build-node-helper.mjs, run by postinstall and
# by CI's electron-native-rebuild action).
build/node-helper/
*.log
.DS_Store
.env
.env.*
*.tsbuildinfo

# Vite writes a transpiled copy of the config next to it, stamped with a timestamp
# and the ABSOLUTE repo path. One `git add -A` committed it (175e7f8).
electron.vite.config.*.mjs
electron.vite.config.*.js

# Claude Code creates isolated worktrees here (each is a registered git worktree of
# THIS repo). They are working copies, not source — the same trap as the Vite config
# above: one `git add -A` and the whole tree lands in a commit.
.claude/worktrees/

# aider writes its chat transcript into the repo root.
.aider.chat.history.md
.aider*

# The in-repo device-key N-API addon compiles per-machine (scripts/build-device-key.mjs,
# postinstall, rebuild:native) — like node-pty/better-sqlite3, its build output is not committed.
src/backend/platform/device-key/build/
