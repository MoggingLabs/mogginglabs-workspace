<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
  <dict>
    <!-- Electron/V8 needs a writable+executable JIT heap; hardened runtime blocks it by default. -->
    <key>com.apple.security.cs.allow-jit</key>
    <true/>
    <key>com.apple.security.cs.allow-unsigned-executable-memory</key>
    <true/>
    <!-- Load our from-source native modules (node-pty, better-sqlite3) not signed by Apple. -->
    <key>com.apple.security.cs.disable-library-validation</key>
    <true/>
    <!-- Existed for the Electron-as-Node daemon, which the runtime split retired
         (ADR 0016: the daemon runs on resources/node-helper now and runAsNode is off).
         Kept until the operator's signing step verifies a notarized build WITHOUT it on
         real hardware — dropping it is a hardening win to take there, not blind here. -->
    <key>com.apple.security.cs.allow-dyld-environment-variables</key>
    <true/>
  </dict>
</plist>
