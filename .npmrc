# Build native modules FROM SOURCE — no prebuilt binaries. The proper implementation now
# that the VS C++ Build Tools are installed: node-pty (official) and better-sqlite3 compile
# against the exact Node/Electron ABI (see also `buildDependenciesFromSource` in
# electron-builder.yml, which forces the Electron-ABI rebuild from source).
#
# NOTE: CI runs `npm ci --ignore-scripts` (typecheck/build only, native modules externalized),
# so this does not force compilation on the runners.
build_from_source=true
