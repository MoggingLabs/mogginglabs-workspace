{
  "id": "atlassian",
  "label": "Jira / Atlassian",
  "source": "https://support.atlassian.com/rovo/docs/getting-started-with-the-atlassian-remote-mcp-server/",
  "docs": "https://developer.atlassian.com/cloud/",
  "mcp": {
    "transport": "http",
    "url": "https://mcp.atlassian.com/v1/mcp"
  },
  "methods": [
    {
      "key": "browser",
      "kind": "oauth",
      "name": "Sign in with your browser",
      "rank": 1,
      "endpoints": {
        "discovery": "mcp"
      }
    },
    {
      "key": "cli-owned",
      "kind": "cliOwned",
      "name": "Let Claude Code sign in itself (advanced)",
      "rank": 90
    }
  ],
  "profile": {
    "via": "rest",
    "url": "https://api.atlassian.com/me",
    "paths": {
      "id": "account_id",
      "email": "email",
      "name": "name",
      "imageUrl": "picture"
    },
    "source": "https://developer.atlassian.com/cloud/jira/platform/oauth-2-3lo-apps/"
  },
  "verification": {
    "method": "GET",
    "endpoint": "https://api.atlassian.com/me",
    "source": "https://developer.atlassian.com/cloud/jira/platform/oauth-2-3lo-apps/"
  },
  "grantCopy": "Jira issues and Confluence pages your account can reach.",
  "verifiedAt": "2026-07-15"
}
