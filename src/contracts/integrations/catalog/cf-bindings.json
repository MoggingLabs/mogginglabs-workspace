{
  "id": "cf-bindings",
  "label": "Cloudflare Workers",
  "source": "https://developers.cloudflare.com/agents/model-context-protocol/mcp-servers-for-cloudflare/",
  "docs": "https://developers.cloudflare.com/api/",
  "group": "cloudflare",
  "mcp": {
    "transport": "http",
    "url": "https://bindings.mcp.cloudflare.com/mcp"
  },
  "methods": [
    {
      "key": "browser",
      "kind": "oauth",
      "name": "Sign in with your browser",
      "rank": 1,
      "endpoints": {
        "discovery": "mcp"
      }
    },
    {
      "key": "cli-owned",
      "kind": "cliOwned",
      "name": "Let Claude Code sign in itself (advanced)",
      "rank": 90
    }
  ],
  "retry": {
    "atHeader": "retry-after",
    "errorCodes": [
      "429"
    ]
  },
  "grantCopy": "Workers, KV, R2, D1 - an agent here deploys and mutates real infrastructure on your account. Grant narrowly.",
  "verifiedAt": "2026-07-15"
}
