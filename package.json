{
  "name": "mogginglabs-workspace",
  "version": "0.15.1",
  "description": "A neutral, reliable, cross-platform organizer for AI coding-agent CLIs. Your keys, your CLIs.",
  "author": "MoggingLabs",
  "license": "SEE LICENSE IN LICENSE",
  "private": true,
  "main": "./out/main/index.js",
  "bin": {
    "mogging": "bin/mogging.mjs",
    "mogging-mcp": "bin/mogging-mcp.mjs"
  },
  "scripts": {
    "postinstall": "electron-builder install-app-deps && node scripts/build-device-key.mjs && node scripts/build-node-helper.mjs",
    "rebuild:native": "node scripts/rebuild-native.mjs",
    "build:node-helper": "node scripts/build-node-helper.mjs",
    "build:device-key": "node scripts/build-device-key.mjs",
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "start": "electron-vite preview",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "test": "vitest run",
    "catalog:agent-settings:update": "node scripts/update-agent-settings-catalog.mjs",
    "catalog:agent-settings:check": "node scripts/check-agent-settings-catalog.mjs",
    "catalog:grammars:update": "node scripts/update-grammar-catalog.mjs",
    "catalog:grammars:check": "node scripts/check-grammar-catalog.mjs",
    "catalog:integrations:check": "node scripts/check-catalog.mjs",
    "dist": "electron-vite build && electron-builder --publish never",
    "dist:win": "electron-vite build && electron-builder --win --publish never",
    "dist:mac": "electron-vite build && electron-builder --mac --publish never",
    "smoke:git-pure": "tsx scripts/git-feature-pure-smoke.ts",
    "smoke:remote-bootstrap-pure": "tsx scripts/remote-bootstrap-pure-smoke.ts",
    "smoke:connections-pure": "tsx scripts/connections-pure-smoke.ts",
    "smoke:toolcred-pure": "tsx scripts/toolcred-pure-smoke.ts",
    "smoke:preregistered-client-pure": "tsx scripts/preregistered-client-pure-smoke.ts"
  },
  "dependencies": {
    "@fontsource-variable/jetbrains-mono": "^5.2.8",
    "@sentry/electron": "^7.15.0",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/addon-search": "^0.16.0",
    "@xterm/addon-serialize": "^0.14.0",
    "@xterm/addon-webgl": "^0.19.0",
    "@xterm/xterm": "^6.0.0",
    "better-sqlite3": "^12.11.1",
    "electron-updater": "^6.3.0",
    "jsonc-parser": "^3.3.1",
    "node-pty": "1.1.0",
    "posthog-node": "^5.39.2",
    "toml-eslint-parser": "^1.0.3",
    "web-tree-sitter": "^0.26.11",
    "write-file-atomic": "^7.0.0",
    "yaml": "^2.9.0"
  },
  "devDependencies": {
    "@electron/fuses": "^2.1.3",
    "@eslint/js": "^10.0.1",
    "@types/better-sqlite3": "^7.6.13",
    "@types/write-file-atomic": "^4.0.3",
    "electron": "^39.8.10",
    "electron-builder": "^26.15.6",
    "electron-vite": "^5.0.0",
    "eslint": "^10.7.0",
    "globals": "^17.7.0",
    "node-gyp": "^13.0.0",
    "tsx": "^4.20.6",
    "typescript": "^5.6.3",
    "typescript-eslint": "^8.64.0",
    "vite": "^7.3.6",
    "vitest": "^4.1.10"
  },
  "overrides": {
    "node-gyp": "^13.0.0"
  }
}
