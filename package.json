{
  "name": "mogginglabs-workspace",
  "version": "0.8.1",
  "description": "A neutral, reliable, cross-platform organizer for AI coding-agent CLIs. Your keys, your CLIs — no subscription to us.",
  "author": "MoggingLabs",
  "license": "SEE LICENSE IN LICENSE",
  "private": true,
  "main": "./out/main/index.js",
  "bin": {
    "mogging": "bin/mogging.mjs",
    "mogging-mcp": "bin/mogging-mcp.mjs"
  },
  "scripts": {
    "postinstall": "electron-builder install-app-deps",
    "rebuild:native": "node scripts/rebuild-native.mjs",
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "start": "electron-vite preview",
    "typecheck": "tsc --noEmit",
    "dist": "electron-vite build && electron-builder --publish never",
    "dist:win": "electron-vite build && electron-builder --win --publish never",
    "dist:mac": "electron-vite build && electron-builder --mac --publish never"
  },
  "dependencies": {
    "@fontsource-variable/jetbrains-mono": "^5.2.8",
    "@sentry/electron": "^7.15.0",
    "@xterm/addon-fit": "^0.10.0",
    "@xterm/addon-search": "^0.15.0",
    "@xterm/addon-serialize": "^0.14.0",
    "@xterm/addon-webgl": "^0.18.0",
    "@xterm/xterm": "^5.5.0",
    "better-sqlite3": "^12.11.1",
    "electron-updater": "^6.3.0",
    "node-pty": "1.1.0",
    "posthog-node": "^5.39.2"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "electron": "^39.8.10",
    "electron-builder": "^26.15.6",
    "electron-vite": "^5.0.0",
    "node-gyp": "^13.0.0",
    "typescript": "^5.6.3",
    "vite": "^7.3.6"
  },
  "overrides": {
    "node-gyp": "^13.0.0"
  }
}
